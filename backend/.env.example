APP_NAME=FlowLens API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://flowlens:flowlens@localhost:5432/flowlens
SECRET_KEY=replace-with-a-long-random-value-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_CHAT_MODEL=
ANTHROPIC_ANALYSIS_MAX_OUTPUT_TOKENS=8192
ANTHROPIC_CHAT_MAX_OUTPUT_TOKENS=2048
STORAGE_LOCAL_PATH=./data/uploads
MAX_UPLOAD_SIZE_BYTES=26214400
