# Docker Compose
POSTGRES_DB=flowlens
POSTGRES_USER=flowlens
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+psycopg://flowlens:change-me-in-production@db:5432/flowlens

# API security
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-value-before-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# AI and document storage
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_CHAT_MODEL=
ANTHROPIC_ANALYSIS_MAX_OUTPUT_TOKENS=16384
ANTHROPIC_CHAT_MAX_OUTPUT_TOKENS=2048
STORAGE_LOCAL_PATH=/data/uploads
MAX_UPLOAD_SIZE_BYTES=26214400
